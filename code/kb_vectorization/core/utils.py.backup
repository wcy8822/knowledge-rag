import gc
import hashlib
import logging
import os
import re
import sys
from datetime import datetime
from pathlib import Path
from typing import Any, Callable, Dict, List, Optional, Tuple

try:
    import psutil
    PSUTIL_AVAILABLE = True
except ImportError:
    PSUTIL_AVAILABLE = False

try:
    import numpy as np
    NUMPY_AVAILABLE = True
except ImportError:
    NUMPY_AVAILABLE = False


def setup_logger(
    name: str,
    log_dir: str = "./logs",
    level: str = "INFO",
    console_output: bool = True,
    file_output: bool = True,
    json_format: bool = False
) -> logging.Logger:
    """
    设置日志记录器

    Args:
        name: 日志记录器名称
        log_dir: 日志目录
        level: 日志级别
        console_output: 是否输出到控制台
        file_output: 是否输出到文件
        json_format: 是否使用 JSON 格式

    Returns:
        配置好的日志记录器
    """
    # 创建日志目录
    os.makedirs(log_dir, exist_ok=True)

    # 创建日志记录器
    logger = logging.getLogger(name)
    logger.setLevel(getattr(logging, level.upper(), logging.INFO))

    # 清除已有的处理器
    logger.handlers.clear()

    # 日志格式
    if json_format:
        formatter = logging.Formatter('{"timestamp": "%(asctime)s", "name": "%(name)s", "level": "%(levelname)s", "message": "%(message)s"}')
    else:
        formatter = logging.Formatter('%(asctime)s - %(name)s - %(levelname)s - %(message)s')

    # 控制台处理器
    if console_output:
        console_handler = logging.StreamHandler(sys.stdout)
        console_handler.setLevel(getattr(logging, level.upper(), logging.INFO))
        console_handler.setFormatter(formatter)
        logger.addHandler(console_handler)

    # 文件处理器
    if file_output:
        log_file = os.path.join(log_dir, f"{name}.log")
        file_handler = logging.FileHandler(log_file, encoding='utf-8')
        file_handler.setLevel(getattr(logging, level.upper(), logging.INFO))
        file_handler.setFormatter(formatter)
        logger.addHandler(file_handler)

    return logger


def get_memory_usage() -> float:
    """
    获取当前进程的内存使用量（GB）

    Returns:
        内存使用量（GB）
    """
    if PSUTIL_AVAILABLE:
        process = psutil.Process()
        return process.memory_info().rss / (1024 ** 3)

    # 回退方案
    import resource
    return resource.getrusage(resource.RUSAGE_SELF).ru_maxrss / (1024 ** 2) / 1024


def check_memory(limit_gb: int = 12, raise_on_exceed: bool = False) -> bool:
    """
    检查内存使用是否超限

    Args:
        limit_gb: 内存限制（GB）
        raise_on_exceed: 超限时是否抛出异常

    Returns:
        True: 未超限
        False: 已超限

    Raises:
        MemoryError: 内存超限且 raise_on_exceed=True
    """
    mem_gb = get_memory_usage()

    if mem_gb > limit_gb:
        if raise_on_exceed:
            raise MemoryError(f"内存使用 {mem_gb:.2f}GB 超限 {limit_gb}GB")
        return False

    return True


def force_gc() -> float:
    """
    强制垃圾回收并返回释放后的内存

    Returns:
        释放后的内存使用量（GB）
    """
    gc.collect()
    return get_memory_usage()


def sanitize_text(text: str, mode: str = "moderate") -> str:
    """
    脱敏处理文本

    Args:
        text: 原始文本
        mode: 脱敏模式
            - strict: 严格模式，脱敏所有敏感信息
            - moderate: 中等模式，只脱敏明显敏感信息
            - none: 不脱敏

    Returns:
        脱敏后的文本
    """
    if mode == "none":
        return text

    result = text

    # 敏感模式定义
    patterns = {
        "phone": r"\b1[3-9]\d{9}\b",  # 手机号
        "id_card": r"\b\d{17}[\dXx]\b",  # 身份证号
        "bank_card": r"\b\d{15,19}\b",  # 银行卡号（简化）
        "email": r"\b[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\.[A-Z|a-z]{2,}\b",  # 邮箱
    }

    # 中等模式：只脱敏明显敏感信息
    if mode == "moderate":
        moderate_patterns = ["phone", "email"]
        for pattern_name in moderate_patterns:
            if pattern_name in patterns:
                result = re.sub(patterns[pattern_name], "***", result)

    # 严格模式：脱敏所有敏感信息
    elif mode == "strict":
        for pattern in patterns.values():
            result = re.sub(pattern, "***", result)

    return result


def format_file_size(size_bytes: int) -> str:
    """
    格式化文件大小

    Args:
        size_bytes: 字节数

    Returns:
        格式化后的字符串
    """
    for unit in ['B', 'KB', 'MB', 'GB', 'TB']:
        if size_bytes < 1024.0:
            return f"{size_bytes:.2f} {unit}"
        size_bytes /= 1024.0
    return f"{size_bytes:.2f} PB"


def get_file_hash(file_path: str, algorithm: str = "md5", chunk_size: int = 8192) -> str:
    """
    计算文件哈希值

    Args:
        file_path: 文件路径
        algorithm: 哈希算法 (md5, sha1, sha256)
        chunk_size: 读取块大小

    Returns:
        文件哈希值（十六进制字符串）
    """
    hash_obj = hashlib.new(algorithm)

    try:
        with open(file_path, 'rb') as f:
            while chunk := f.read(chunk_size):
                hash_obj.update(chunk)
    except Exception as e:
        raise RuntimeError(f"计算文件哈希失败: {e}")

    return hash_obj.hexdigest()


def get_file_extension(file_path: str) -> str:
    """
    获取文件扩展名

    Args:
        file_path: 文件路径

    Returns:
        文件扩展名（小写，带点）
    """
    return os.path.splitext(file_path)[1].lower()


def is_text_file(file_path: str, max_bytes: int = 1024) -> bool:
    """
    判断是否为文本文件

    Args:
        file_path: 文件路径
        max_bytes: 检查的最大字节数

    Returns:
        是否为文本文件
    """
    try:
        with open(file_path, 'rb') as f:
            chunk = f.read(max_bytes)
            if not chunk:
                return True
            # 检查是否包含空字节（二进制文件特征）
            return b'\x00' not in chunk
    except Exception:
        return False


def split_text_into_chunks(
    text: str,
    chunk_size: int = 1000,
    overlap: int = 200,
    min_size: int = 100
) -> List[str]:
    """
    将文本分块

    Args:
        text: 原始文本
        chunk_size: 块大小
        overlap: 重叠大小
        min_size: 最小块大小

    Returns:
        文本块列表
    """
    if not text or len(text) <= min_size:
        return [text] if text else []

    chunks = []
    start = 0
    text_len = len(text)

    while start < text_len:
        end = min(start + chunk_size, text_len)

        # 尝试在句子边界分割
        if end < text_len:
            # 寻找最后一个句号、问号、感叹号
            for delimiter in ['。', '！', '？', '.', '!', '?', '\n']:
                last_delimiter = text.rfind(delimiter, start, end)
                if last_delimiter > start + min_size:
                    end = last_delimiter + 1
                    break

        chunk = text[start:end].strip()
        if chunk:
            chunks.append(chunk)

        start = end - overlap
        if start < 0:
            start = end

    return chunks


def normalize_vector(vector: List[float]) -> List[float]:
    """
    归一化向量

    Args:
        vector: 原始向量

    Returns:
        归一化后的向量
    """
    if not vector:
        return vector

    if NUMPY_AVAILABLE:
        arr = np.array(vector, dtype=np.float32)
        norm = np.linalg.norm(arr)
        if norm > 0:
            return (arr / norm).tolist()
        return vector

    # 纯 Python 实现
    norm = sum(x ** 2 for x in vector) ** 0.5
    if norm > 0:
        return [x / norm for x in vector]
    return vector


def cosine_similarity(vec1: List[float], vec2: List[float]) -> float:
    """
    计算余弦相似度

    Args:
        vec1: 向量1
        vec2: 向量2

    Returns:
        余弦相似度（0-1之间）
    """
    if not vec1 or not vec2 or len(vec1) != len(vec2):
        return 0.0

    if NUMPY_AVAILABLE:
        a = np.array(vec1, dtype=np.float32)
        b = np.array(vec2, dtype=np.float32)
        dot = np.dot(a, b)
        norm_a = np.linalg.norm(a)
        norm_b = np.linalg.norm(b)

        if norm_a == 0 or norm_b == 0:
            return 0.0
        return float(dot / (norm_a * norm_b))

    # 纯 Python 实现
    dot = sum(a * b for a, b in zip(vec1, vec2))
    norm_a = sum(a ** 2 for a in vec1) ** 0.5
    norm_b = sum(b ** 2 for b in vec2) ** 0.5

    if norm_a == 0 or norm_b == 0:
        return 0.0
    return dot / (norm_a * norm_b)


def euclidean_distance(vec1: List[float], vec2: List[float]) -> float:
    """
    计算欧氏距离

    Args:
        vec1: 向量1
        vec2: 向量2

    Returns:
        欧氏距离
    """
    if not vec1 or not vec2 or len(vec1) != len(vec2):
        return float('inf')

    if NUMPY_AVAILABLE:
        return float(np.linalg.norm(np.array(vec1) - np.array(vec2)))

    return sum((a - b) ** 2 for a, b in zip(vec1, vec2)) ** 0.5


def md5_vector(text: str, dim: int = 384) -> List[float]:
    """
    使用 MD5 哈希模拟向量（用于 MVP）

    Args:
        text: 输入文本
        dim: 向量维度

    Returns:
        模拟向量
    """
    # 使用 MD5 哈希生成确定性的向量
    md5_hash = hashlib.md5(text.encode('utf-8')).hexdigest()

    # 将十六进制哈希转换为向量
    vector = []
    for i in range(0, len(md5_hash), 2):
        byte_val = int(md5_hash[i:i+2], 16)
        # 归一化到 [0, 1]
        vector.append(byte_val / 255.0)

    # 填充或截断到指定维度
    if len(vector) < dim:
        vector.extend([0.0] * (dim - len(vector)))
    elif len(vector) > dim:
        vector = vector[:dim]

    return normalize_vector(vector)


def ensure_directory(path: str) -> str:
    """
    确保目录存在，不存在则创建

    Args:
        path: 目录路径

    Returns:
        目录路径
    """
    os.makedirs(path, exist_ok=True)
    return path


def safe_file_read(file_path: str, encoding: str = 'utf-8') -> Optional[str]:
    """
    安全读取文件

    Args:
        file_path: 文件路径
        encoding: 编码

    Returns:
        文件内容，失败返回 None
    """
    try:
        with open(file_path, 'r', encoding=encoding) as f:
            return f.read()
    except UnicodeDecodeError:
        # 尝试其他编码
        for enc in ['gbk', 'latin-1', 'utf-16']:
            try:
                with open(file_path, 'r', encoding=enc) as f:
                    return f.read()
            except Exception:
                continue
        return None
    except Exception:
        return None


def timeit(func: Callable) -> Callable:
    """
    函数执行时间装饰器

    Args:
        func: 被装饰的函数

    Returns:
        装饰后的函数
    """
    def wrapper(*args, **kwargs):
        start = datetime.now()
        result = func(*args, **kwargs)
        end = datetime.now()
        duration = (end - start).total_seconds()
        return result, duration
    return wrapper


def retry(max_attempts: int = 3, delay: float = 1.0, exceptions: Tuple = (Exception,)):
    """
    重试装饰器

    Args:
        max_attempts: 最大尝试次数
        delay: 重试延迟（秒）
        exceptions: 需要重试的异常类型

    Returns:
        装饰后的函数
    """
    def decorator(func: Callable) -> Callable:
        def wrapper(*args, **kwargs):
            last_exception = None
            for attempt in range(max_attempts):
                try:
                    return func(*args, **kwargs)
                except exceptions as e:
                    last_exception = e
                    if attempt < max_attempts - 1:
                        import time
                        time.sleep(delay)
                    continue
            raise last_exception
        return wrapper
    return decorator


class ProgressTracker:
    """进度跟踪器"""

    def __init__(self, total: int, description: str = "处理中"):
        """
        初始化进度跟踪器

        Args:
            total: 总数量
            description: 描述信息
        """
        self.total = total
        self.current = 0
        self.description = description
        self.start_time = datetime.now()

    def update(self, increment: int = 1) -> None:
        """
        更新进度

        Args:
            increment: 增量
        """
        self.current += increment

    def get_progress(self) -> Dict[str, Any]:
        """
        获取进度信息

        Returns:
            进度信息字典
        """
        if self.total == 0:
            progress = 1.0
        else:
            progress = self.current / self.total

        elapsed = (datetime.now() - self.start_time).total_seconds()

        # 估算剩余时间
        if self.current > 0 and progress < 1.0:
            remaining = elapsed / progress * (1 - progress)
        else:
            remaining = 0

        return {
            "description": self.description,
            "current": self.current,
            "total": self.total,
            "progress": progress,
            "elapsed": elapsed,
            "remaining": remaining
        }

    def is_complete(self) -> bool:
        """是否完成"""
        return self.current >= self.total


def batch_process(
    items: List[Any],
    batch_size: int,
    processor: Callable[[List[Any]], Any]
) -> List[Any]:
    """
    批量处理

    Args:
        items: 待处理项目列表
        batch_size: 批次大小
        processor: 处理函数

    Returns:
        处理结果列表
    """
    results = []

    for i in range(0, len(items), batch_size):
        batch = items[i:i + batch_size]
        result = processor(batch)
        if result is not None:
            results.append(result)

    return results


